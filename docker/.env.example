# docker/.env
# Variables de entorno para FitPro en producción con Docker.
# NUNCA subas este archivo a Git — contiene claves secretas.

# -----------------------------------------------
# APLICACIÓN
# -----------------------------------------------
APP_NAME=FitPro - Gestión Fitness
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# -----------------------------------------------
# BASE DE DATOS SQLite
# -----------------------------------------------
DATABASE_URL=sqlite:////app/data/fitpro.db

# -----------------------------------------------
# SEGURIDAD JWT
# Genera SECRET_KEY con: python -c "import secrets; print(secrets.token_hex(48))"
# -----------------------------------------------
SECRET_KEY=CAMBIA-ESTO-POR-UNA-CLAVE-SECRETA-MUY-LARGA-Y-ALEATORIA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------
# CORS
# -----------------------------------------------
CORS_ALLOW_ALL=True

# -----------------------------------------------
# SISTEMA DE LICENCIAS MENSUALES
# IMPORTANTE: Usar siempre fechas válidas del calendario.
# Junio tiene 30 días (no 31), febrero 28/29, etc.
# Formato estricto: YYYY-MM-DD
# -----------------------------------------------
LICENSE_KEY=DEMO-FITPRO-2025
LICENSE_EXPIRY=2027-06-30
LICENSE_WARNING_DAYS=5

# -----------------------------------------------
# RATE LIMITING
# -----------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH=10/minute

# -----------------------------------------------
# CONTRASEÑAS
# -----------------------------------------------
MIN_PASSWORD_LENGTH=8
BCRYPT_ROUNDS=12